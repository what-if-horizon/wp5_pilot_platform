# ── Admin panel ──────────────────────────────────────────────────────────────
# Passphrase for the researcher admin panel at /admin (required).
ADMIN_PASSPHRASE=changeme

# ── Infrastructure ───────────────────────────────────────────────────────────
# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://wp5user:wp5pass@db:5432/wp5

# Redis connection string (matches docker-compose.yml defaults)
REDIS_URL=redis://redis:6379/0

# ── API keys for LLM providers ────────────────────────────────────────────────
# Which keys you need depends on director_llm_provider / performer_llm_provider

# Anthropic (Claude) — used as Director by default
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# HuggingFace Inference API — used as Performer by default
# Get your key from: https://huggingface.co/settings/tokens
HF_API_KEY=your_api_key_here

# Google Gemini — available as alternative provider
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Mistral — available as alternative provider
# Get your key from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_api_key_here

# Konstanz vLLM endpoint — university-hosted model
KONSTANZ_API_KEY=your_api_key_here


